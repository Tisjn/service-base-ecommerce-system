# Copy this file to .env and fill in secure values for local/dev use.
# All variables below are required because code no longer uses hardcoded defaults.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_data
DB_USER=root
DB_PASSWORD=your_password
SPRING_JPA_DDL=update

# Minimum 32 chars for HS256 key
JWT_SECRET=your-very-strong-32-plus-char-secret
JWT_EXPIRE_MS=86400000

