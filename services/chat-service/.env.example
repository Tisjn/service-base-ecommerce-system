PORT=3008
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Use the same secret as auth-service so Socket.io and REST calls can verify access tokens.
JWT_SECRET=replace_with_the_same_secret_as_auth_service

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace_with_access_key
AWS_SECRET_ACCESS_KEY=replace_with_secret_key
DDB_CHAT_ROOMS_TABLE=chat_rooms
DDB_CHAT_MESSAGES_TABLE=chat_messages

UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_FILE_TYPES=application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
