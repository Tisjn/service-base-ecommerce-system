# Shared AWS RDS MySQL
RDS_HOST=your-rds-endpoint.ap-southeast-1.rds.amazonaws.com
RDS_PORT=3306
RDS_USER=admin
RDS_PASSWORD=your_rds_password
RDS_SSL=true

# Shared Redis
REDIS_HOST=redis-cache
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth service
AUTH_PORT=3001
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
PASSWORD_SALT_ROUNDS=12
REGISTER_RATE_LIMIT_WINDOW_MS=60000
REGISTER_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=5
PASSWORD_RATE_LIMIT_WINDOW_MS=60000
PASSWORD_RATE_LIMIT_MAX=5
DB_NAME=authdb
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourapp@gmail.com
SMTP_PASS=your_gmail_app_password

# User service
USER_PORT=3002
USER_DB_NAME=userdb
ORDER_SERVICE_URL=http://order-service:3004

# Product service
PRODUCT_PORT=3003
PRODUCT_DB_NAME=productdb

# Order service
ORDER_PORT=3004
ORDER_DB_NAME=orderdb
PRODUCT_SERVICE_URL=http://product-service:3003
PAYMENT_SERVICE_URL=http://payment-service:3005

# Payment service
PAYMENT_PORT=3005
PAYMENT_DB_NAME=paymentdb
PAYMENT_GATEWAY_URL=https://mock-gateway.internal
WEBHOOK_SECRET=webhook_hmac_secret
